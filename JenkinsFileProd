pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'BUILD_TARGET',
            choices: [
                'backend_frontend',
                'instagram_banner_bot',
                'linkedin_banner_bot',
                'av_bot',
                'yehp_banner_bot',
                'ai_devops_reel_factory'
            ],
            description: 'Choose which production build/deploy path to run.'
        )
    }

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
        BACKEND_IMAGE = "${DOCKER_CREDS_USR}/tutorlix-backend-prod:latest"
        FRONTEND_IMAGE = "${DOCKER_CREDS_USR}/tutorlix-frontend-prod:latest"
        INSTAGRAM_BOT_IMAGE = "${DOCKER_CREDS_USR}/tutorlix-instagram-banner-bot-prod:latest"
        LINKEDIN_BOT_IMAGE = "${DOCKER_CREDS_USR}/linkedin-banner-bot-prod:latest"
        AV_BOT_IMAGE = "${DOCKER_CREDS_USR}/av-bot-prod:latest"
        YEHP_BOT_IMAGE = "${DOCKER_CREDS_USR}/yehp-banner-bot-prod:latest"
        AI_DEVOPS_REEL_IMAGE = "${DOCKER_CREDS_USR}/ai-devops-reel-factory-prod:latest"
        INSTAGRAM_BOT_CONTAINER = 'instagram-banner-bot-prod'
        INSTAGRAM_BOT_ENV_FILE = '/var/www/tutorlix-prod/instagram-bot.env'
        INSTAGRAM_BOT_OUTPUT_DIR = '/var/www/tutorlix-prod/instagram-bot-output'
        LINKEDIN_BOT_CONTAINER = 'linkedin-banner-bot-prod'
        LINKEDIN_BOT_ENV_FILE = '/var/www/tutorlix-prod/linkedin-bot.env'
        LINKEDIN_BOT_OUTPUT_DIR = '/var/www/tutorlix-prod/linkedin-bot-output'
        AV_BOT_CONTAINER = 'av-bot-prod'
        AV_BOT_ENV_FILE = '/var/www/tutorlix-prod/av-bot.env'
        AV_BOT_OUTPUT_DIR = '/var/www/tutorlix-prod/av-bot-output'
        YEHP_BOT_CONTAINER = 'yehp-banner-bot-prod'
        YEHP_BOT_ENV_FILE = '/var/www/tutorlix-prod/yehp-bot.env'
        YEHP_BOT_OUTPUT_DIR = '/var/www/tutorlix-prod/yehp-bot-output'
        AI_DEVOPS_REEL_CONTAINER = 'ai-devops-reel-factory-prod'
        AI_DEVOPS_REEL_ENV_FILE = '/var/www/tutorlix-prod/ai-devops-reel-factory.env'
        AI_DEVOPS_REEL_OUTPUT_DIR = '/var/www/tutorlix-prod/ai-devops-reel-factory-output'
        AI_DEVOPS_REEL_ASSETS_DIR = '/var/www/tutorlix-prod/ai-devops-reel-factory-assets'
        AI_DEVOPS_REEL_MODEL_CACHE_DIR = '/var/www/tutorlix-prod/ai-devops-reel-factory-model-cache'
        AI_DEVOPS_REEL_LIVEPORTRAIT_DIR = '/var/www/tutorlix-prod/LivePortrait'
        AI_DEVOPS_REEL_WAV2LIP_DIR = '/var/www/tutorlix-prod/Wav2Lip'
        AI_DEVOPS_REEL_PORT = '11004'
        AI_DEVOPS_REEL_GPU_ARGS = ''
        BACKEND_SECRET_NAME = 'backend-prod-env'
        ROLLOUT_TIMEOUT = '600s'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                '''
            }
        }

        stage('Selected Target') {
            steps {
                echo "Selected production build target: ${params.BUILD_TARGET}"
            }
        }

        stage('Build And Push Backend + Frontend Images') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            parallel {
                stage('Backend Image') {
                    steps {
                        sh '''
                            set -e
                            echo "🚀 Building backend prod image..."
                            docker build \
                            --network=host \
                            -f backend/Dockerfile.prod \
                            -t $BACKEND_IMAGE \
                            ./backend

                            echo "📤 Pushing backend prod image..."
                            docker push $BACKEND_IMAGE
                        '''
                    }
                }

                stage('Frontend Image') {
                    steps {
                        sh '''
                            set -e
                            echo "🚀 Building frontend prod image..."
                            docker build \
                            --network=host \
                            -f frontend/Dockerfile.prod \
                            -t $FRONTEND_IMAGE \
                            ./frontend

                            echo "📤 Pushing frontend prod image..."
                            docker push $FRONTEND_IMAGE
                        '''
                    }
                }
            }
        }

        stage('Build And Push Instagram Banner Bot Image') {
            when {
                expression { params.BUILD_TARGET == 'instagram_banner_bot' }
            }
            steps {
                sh '''
                    set -e
                    echo "🚀 Building Instagram banner bot prod image..."
                    docker build \
                    --network=host \
                    -f bots/instagram_banner_bot/Dockerfile.prod \
                    -t $INSTAGRAM_BOT_IMAGE \
                    .

                    echo "📤 Pushing Instagram banner bot prod image..."
                    docker push $INSTAGRAM_BOT_IMAGE
                '''
            }
        }

        stage('Build And Push LinkedIn Banner Bot Image') {
            when {
                expression { params.BUILD_TARGET == 'linkedin_banner_bot' }
            }
            steps {
                sh '''
                    set -e
                    echo "🚀 Building LinkedIn banner bot prod image..."
                    docker build \
                    --network=host \
                    -f bots/linkedin_banner_bot/Dockerfile.prod \
                    -t $LINKEDIN_BOT_IMAGE \
                    .

                    echo "📤 Pushing LinkedIn banner bot prod image..."
                    docker push $LINKEDIN_BOT_IMAGE
                '''
            }
        }

        stage('Build And Push YEHP Banner Bot Image') {
            when {
                expression { params.BUILD_TARGET == 'yehp_banner_bot' }
            }
            steps {
                sh '''
                    set -e
                    echo "🚀 Building YEHP banner bot prod image..."
                    docker build \
                    --network=host \
                    -f bots/yehp_banner_bot/Dockerfile.prod \
                    -t $YEHP_BOT_IMAGE \
                    .

                    echo "📤 Pushing YEHP banner bot prod image..."
                    docker push $YEHP_BOT_IMAGE
                '''
            }
        }

        stage('Build And Push AV Bot Image') {
            when {
                expression { params.BUILD_TARGET == 'av_bot' }
            }
            steps {
                sh '''
                    set -e
                    echo "🚀 Building AV bot prod image..."
                    docker build \
                    --network=host \
                    -f bots/av_bot/Dockerfile.prod \
                    -t $AV_BOT_IMAGE \
                    .

                    echo "📤 Pushing AV bot prod image..."
                    docker push $AV_BOT_IMAGE
                '''
            }
        }

        stage('Build And Push AI DevOps Reel Factory Image') {
            when {
                expression { params.BUILD_TARGET == 'ai_devops_reel_factory' }
            }
            steps {
                sh '''
                    set -e
                    echo "Building AI DevOps Reel Factory prod image..."
                    docker build \
                    --network=host \
                    -f bots/ai_devops_reel_factory/Dockerfile.prod \
                    -t $AI_DEVOPS_REEL_IMAGE \
                    .

                    echo "Pushing AI DevOps Reel Factory prod image..."
                    docker push $AI_DEVOPS_REEL_IMAGE
                '''
            }
        }

        stage('Run Instagram Banner Bot Container') {
            when {
                expression { params.BUILD_TARGET == 'instagram_banner_bot' }
            }
            steps {
                sh '''
                    set -e

                    if [ ! -f "$INSTAGRAM_BOT_ENV_FILE" ]; then
                        echo "❌ Instagram bot env file not found: $INSTAGRAM_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ ! -r "$INSTAGRAM_BOT_ENV_FILE" ]; then
                        echo "❌ Jenkins cannot read Instagram bot env file: $INSTAGRAM_BOT_ENV_FILE"
                        echo "   Fix file permissions before rerunning this job."
                        exit 1
                    fi

                    OPENAI_IMAGE_ENABLED=$(grep -E '^OPENAI_IMAGE_ENABLED=' "$INSTAGRAM_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_API_KEY=$(grep -E '^OPENAI_API_KEY=' "$INSTAGRAM_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_IMAGE_ENABLED=${OPENAI_IMAGE_ENABLED:-true}

                    if [ "$OPENAI_IMAGE_ENABLED" != "false" ] && [ -z "$OPENAI_API_KEY" ]; then
                        echo "❌ OPENAI_API_KEY is required in $INSTAGRAM_BOT_ENV_FILE"
                        exit 1
                    fi

                    mkdir -p "$INSTAGRAM_BOT_OUTPUT_DIR"

                    echo "📥 Pulling latest Instagram banner bot image..."
                    docker pull "$INSTAGRAM_BOT_IMAGE"

                    echo "🧹 Removing old Instagram banner bot container..."
                    docker rm -f "$INSTAGRAM_BOT_CONTAINER" || true

                    echo "🚀 Starting Instagram banner bot container..."
                    docker run -d \
                      --name "$INSTAGRAM_BOT_CONTAINER" \
                      --restart unless-stopped \
                      --network host \
                      --env-file "$INSTAGRAM_BOT_ENV_FILE" \
                      -v "$INSTAGRAM_BOT_OUTPUT_DIR:/app/bots/instagram_banner_bot/output" \
                      "$INSTAGRAM_BOT_IMAGE"

                    docker ps --filter "name=$INSTAGRAM_BOT_CONTAINER"
                    sleep 5
                    docker logs "$INSTAGRAM_BOT_CONTAINER" --tail=80
                '''
            }
        }

        stage('Run LinkedIn Banner Bot Container') {
            when {
                expression { params.BUILD_TARGET == 'linkedin_banner_bot' }
            }
            steps {
                sh '''
                    set -e

                    if [ ! -f "$LINKEDIN_BOT_ENV_FILE" ]; then
                        echo "❌ LinkedIn bot env file not found: $LINKEDIN_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ ! -r "$LINKEDIN_BOT_ENV_FILE" ]; then
                        echo "❌ Jenkins cannot read LinkedIn bot env file: $LINKEDIN_BOT_ENV_FILE"
                        echo "   Fix file permissions before rerunning this job."
                        exit 1
                    fi

                    OPENAI_IMAGE_ENABLED=$(grep -E '^OPENAI_IMAGE_ENABLED=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_API_KEY=$(grep -E '^OPENAI_API_KEY=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_IMAGE_ENABLED=${OPENAI_IMAGE_ENABLED:-false}

                    if [ "$OPENAI_IMAGE_ENABLED" != "false" ] && [ -z "$OPENAI_API_KEY" ]; then
                        echo "❌ OPENAI_API_KEY is required in $LINKEDIN_BOT_ENV_FILE when OPENAI_IMAGE_ENABLED is true"
                        exit 1
                    fi

                    BUFFER_API_KEY=$(grep -E '^BUFFER_API_KEY=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    BUFFER_ACCESS_TOKEN=$(grep -E '^BUFFER_ACCESS_TOKEN=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    BUFFER_CHANNEL_IDS=$(grep -E '^BUFFER_CHANNEL_IDS=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    PUBLIC_MEDIA_BASE_URL=$(grep -E '^PUBLIC_MEDIA_BASE_URL=' "$LINKEDIN_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')

                    if [ -z "$BUFFER_API_KEY" ] && [ -z "$BUFFER_ACCESS_TOKEN" ]; then
                        echo "❌ BUFFER_API_KEY is required in $LINKEDIN_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ -z "$BUFFER_CHANNEL_IDS" ]; then
                        echo "❌ BUFFER_CHANNEL_IDS is required in $LINKEDIN_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ -z "$PUBLIC_MEDIA_BASE_URL" ]; then
                        echo "❌ PUBLIC_MEDIA_BASE_URL is required in $LINKEDIN_BOT_ENV_FILE"
                        exit 1
                    fi

                    mkdir -p "$LINKEDIN_BOT_OUTPUT_DIR"

                    echo "📥 Pulling latest LinkedIn banner bot image..."
                    docker pull "$LINKEDIN_BOT_IMAGE"

                    echo "🧹 Removing old LinkedIn banner bot container..."
                    docker rm -f "$LINKEDIN_BOT_CONTAINER" || true

                    echo "🚀 Starting LinkedIn banner bot container..."
                    docker run -d \
                      --name "$LINKEDIN_BOT_CONTAINER" \
                      --restart unless-stopped \
                      --network host \
                      --env-file "$LINKEDIN_BOT_ENV_FILE" \
                      -v "$LINKEDIN_BOT_OUTPUT_DIR:/app/bots/linkedin_banner_bot/output" \
                      "$LINKEDIN_BOT_IMAGE"

                    docker ps --filter "name=$LINKEDIN_BOT_CONTAINER"
                    sleep 5
                    docker logs "$LINKEDIN_BOT_CONTAINER" --tail=80
                '''
            }
        }

        stage('Run AV Bot Container') {
            when {
                expression { params.BUILD_TARGET == 'av_bot' }
            }
            steps {
                sh '''
                    set -e

                    if [ ! -f "$AV_BOT_ENV_FILE" ]; then
                        echo "❌ AV bot env file not found: $AV_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ ! -r "$AV_BOT_ENV_FILE" ]; then
                        echo "❌ Jenkins cannot read AV bot env file: $AV_BOT_ENV_FILE"
                        echo "   Fix file permissions before rerunning this job."
                        exit 1
                    fi

                    BUFFER_API_KEY=$(grep -E '^BUFFER_API_KEY=' "$AV_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    BUFFER_ACCESS_TOKEN=$(grep -E '^BUFFER_ACCESS_TOKEN=' "$AV_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    BUFFER_CHANNEL_IDS=$(grep -E '^BUFFER_CHANNEL_IDS=' "$AV_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    PUBLIC_MEDIA_BASE_URL=$(grep -E '^PUBLIC_MEDIA_BASE_URL=' "$AV_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')

                    if [ -z "$BUFFER_API_KEY" ] && [ -z "$BUFFER_ACCESS_TOKEN" ]; then
                        echo "❌ BUFFER_API_KEY is required in $AV_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ -z "$BUFFER_CHANNEL_IDS" ]; then
                        echo "❌ BUFFER_CHANNEL_IDS is required in $AV_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ -z "$PUBLIC_MEDIA_BASE_URL" ]; then
                        echo "❌ PUBLIC_MEDIA_BASE_URL is required in $AV_BOT_ENV_FILE"
                        exit 1
                    fi

                    mkdir -p "$AV_BOT_OUTPUT_DIR"

                    echo "📥 Pulling latest AV bot image..."
                    docker pull "$AV_BOT_IMAGE"

                    echo "🧹 Removing old AV bot container..."
                    docker rm -f "$AV_BOT_CONTAINER" || true

                    echo "🚀 Starting AV bot container..."
                    docker run -d \
                      --name "$AV_BOT_CONTAINER" \
                      --restart unless-stopped \
                      --network host \
                      --env-file "$AV_BOT_ENV_FILE" \
                      -v "$AV_BOT_OUTPUT_DIR:/app/bots/av_bot/output" \
                      "$AV_BOT_IMAGE"

                    docker ps --filter "name=$AV_BOT_CONTAINER"
                    sleep 5
                    docker logs "$AV_BOT_CONTAINER" --tail=80
                '''
            }
        }

        stage('Run YEHP Banner Bot Container') {
            when {
                expression { params.BUILD_TARGET == 'yehp_banner_bot' }
            }
            steps {
                sh '''
                    set -e

                    if [ ! -f "$YEHP_BOT_ENV_FILE" ]; then
                        echo "❌ YEHP bot env file not found: $YEHP_BOT_ENV_FILE"
                        exit 1
                    fi

                    if [ ! -r "$YEHP_BOT_ENV_FILE" ]; then
                        echo "❌ Jenkins cannot read YEHP bot env file: $YEHP_BOT_ENV_FILE"
                        echo "   Fix file permissions before rerunning this job."
                        exit 1
                    fi

                    OPENAI_IMAGE_ENABLED=$(grep -E '^OPENAI_IMAGE_ENABLED=' "$YEHP_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_API_KEY=$(grep -E '^OPENAI_API_KEY=' "$YEHP_BOT_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    OPENAI_IMAGE_ENABLED=${OPENAI_IMAGE_ENABLED:-true}

                    if [ "$OPENAI_IMAGE_ENABLED" != "false" ] && [ -z "$OPENAI_API_KEY" ]; then
                        echo "❌ OPENAI_API_KEY is required in $YEHP_BOT_ENV_FILE"
                        exit 1
                    fi

                    mkdir -p "$YEHP_BOT_OUTPUT_DIR"

                    echo "📥 Pulling latest YEHP banner bot image..."
                    docker pull "$YEHP_BOT_IMAGE"

                    echo "🧹 Removing old YEHP banner bot container..."
                    docker rm -f "$YEHP_BOT_CONTAINER" || true

                    echo "🚀 Starting YEHP banner bot container..."
                    docker run -d \
                      --name "$YEHP_BOT_CONTAINER" \
                      --restart unless-stopped \
                      --network host \
                      --env-file "$YEHP_BOT_ENV_FILE" \
                      -e BOT_RUN_ON_START=true \
                      -v "$YEHP_BOT_OUTPUT_DIR:/app/bots/yehp_banner_bot/output" \
                      "$YEHP_BOT_IMAGE"

                    docker ps --filter "name=$YEHP_BOT_CONTAINER"
                    sleep 5
                    docker logs "$YEHP_BOT_CONTAINER" --tail=80
                '''
            }
        }

        stage('Run AI DevOps Reel Factory Container') {
            when {
                expression { params.BUILD_TARGET == 'ai_devops_reel_factory' }
            }
            steps {
                sh '''
                    set -e

                    if [ ! -f "$AI_DEVOPS_REEL_ENV_FILE" ]; then
                        echo "AI DevOps Reel Factory env file not found: $AI_DEVOPS_REEL_ENV_FILE"
                        exit 1
                    fi

                    if [ ! -r "$AI_DEVOPS_REEL_ENV_FILE" ]; then
                        echo "Jenkins cannot read AI DevOps Reel Factory env file: $AI_DEVOPS_REEL_ENV_FILE"
                        echo "Fix file permissions before rerunning this job."
                        exit 1
                    fi

                    INSTAGRAM_DRY_RUN=$(grep -E '^INSTAGRAM_DRY_RUN=' "$AI_DEVOPS_REEL_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    INSTAGRAM_USER_ID=$(grep -E '^INSTAGRAM_USER_ID=' "$AI_DEVOPS_REEL_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    INSTAGRAM_ACCESS_TOKEN=$(grep -E '^INSTAGRAM_ACCESS_TOKEN=' "$AI_DEVOPS_REEL_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    PUBLIC_VIDEO_BASE_URL=$(grep -E '^PUBLIC_VIDEO_BASE_URL=' "$AI_DEVOPS_REEL_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    COQUI_TOS_AGREED=$(grep -E '^COQUI_TOS_AGREED=' "$AI_DEVOPS_REEL_ENV_FILE" | tail -n 1 | cut -d= -f2- | tr -d '"')
                    INSTAGRAM_DRY_RUN=${INSTAGRAM_DRY_RUN:-false}

                    if [ "$COQUI_TOS_AGREED" != "1" ]; then
                        echo "COQUI_TOS_AGREED=1 is required in $AI_DEVOPS_REEL_ENV_FILE after you confirm the Coqui XTTS license/TOS."
                        exit 1
                    fi

                    if [ "$INSTAGRAM_DRY_RUN" != "true" ]; then
                        if [ -z "$INSTAGRAM_USER_ID" ]; then
                            echo "INSTAGRAM_USER_ID is required in $AI_DEVOPS_REEL_ENV_FILE"
                            exit 1
                        fi

                        if [ -z "$INSTAGRAM_ACCESS_TOKEN" ]; then
                            echo "INSTAGRAM_ACCESS_TOKEN is required in $AI_DEVOPS_REEL_ENV_FILE"
                            exit 1
                        fi

                        if [ -z "$PUBLIC_VIDEO_BASE_URL" ]; then
                            echo "PUBLIC_VIDEO_BASE_URL is required in $AI_DEVOPS_REEL_ENV_FILE"
                            exit 1
                        fi
                    fi

                    if [ ! -f "$AI_DEVOPS_REEL_ASSETS_DIR/face.png" ]; then
                        echo "face.png not found: $AI_DEVOPS_REEL_ASSETS_DIR/face.png"
                        exit 1
                    fi

                    if [ ! -f "$AI_DEVOPS_REEL_ASSETS_DIR/voice_sample.wav" ]; then
                        echo "voice_sample.wav not found: $AI_DEVOPS_REEL_ASSETS_DIR/voice_sample.wav"
                        exit 1
                    fi

                    HAS_DRIVING_VIDEO=false
                    if [ -d "$AI_DEVOPS_REEL_ASSETS_DIR/driving_videos" ]; then
                        for DRIVING_VIDEO in \
                            "$AI_DEVOPS_REEL_ASSETS_DIR"/driving_videos/*.mp4 \
                            "$AI_DEVOPS_REEL_ASSETS_DIR"/driving_videos/*.mov \
                            "$AI_DEVOPS_REEL_ASSETS_DIR"/driving_videos/*.mkv \
                            "$AI_DEVOPS_REEL_ASSETS_DIR"/driving_videos/*.webm
                        do
                            if [ -f "$DRIVING_VIDEO" ]; then
                                HAS_DRIVING_VIDEO=true
                                break
                            fi
                        done
                    fi

                    if [ "$HAS_DRIVING_VIDEO" != "true" ]; then
                        echo "At least one driving video is required in $AI_DEVOPS_REEL_ASSETS_DIR/driving_videos"
                        exit 1
                    fi

                    if [ ! -f "$AI_DEVOPS_REEL_LIVEPORTRAIT_DIR/inference.py" ]; then
                        echo "LivePortrait inference.py not found: $AI_DEVOPS_REEL_LIVEPORTRAIT_DIR/inference.py"
                        exit 1
                    fi

                    if [ ! -f "$AI_DEVOPS_REEL_WAV2LIP_DIR/inference.py" ]; then
                        echo "Wav2Lip inference.py not found: $AI_DEVOPS_REEL_WAV2LIP_DIR/inference.py"
                        exit 1
                    fi

                    if [ ! -f "$AI_DEVOPS_REEL_WAV2LIP_DIR/wav2lip_gan.pth" ] && [ ! -f "$AI_DEVOPS_REEL_WAV2LIP_DIR/checkpoints/wav2lip_gan.pth" ] && [ ! -f "$AI_DEVOPS_REEL_WAV2LIP_DIR/checkpoints/wav2lip.pth" ]; then
                        echo "Wav2Lip checkpoint not found in $AI_DEVOPS_REEL_WAV2LIP_DIR"
                        exit 1
                    fi

                    mkdir -p "$AI_DEVOPS_REEL_OUTPUT_DIR" "$AI_DEVOPS_REEL_MODEL_CACHE_DIR"

                    echo "Pulling latest AI DevOps Reel Factory image..."
                    docker pull "$AI_DEVOPS_REEL_IMAGE"

                    echo "Removing old AI DevOps Reel Factory container..."
                    docker rm -f "$AI_DEVOPS_REEL_CONTAINER" || true

                    GPU_ARGS="$AI_DEVOPS_REEL_GPU_ARGS"
                    if [ "$GPU_ARGS" = "none" ]; then
                        GPU_ARGS=""
                    fi

                    echo "Starting AI DevOps Reel Factory container..."
                    docker run -d \
                      $GPU_ARGS \
                      --name "$AI_DEVOPS_REEL_CONTAINER" \
                      --restart unless-stopped \
                      --network host \
                      --env-file "$AI_DEVOPS_REEL_ENV_FILE" \
                      -e PYTHONUNBUFFERED=1 \
                      -e PORT="$AI_DEVOPS_REEL_PORT" \
                      -v "$AI_DEVOPS_REEL_OUTPUT_DIR:/app/outputs" \
                      -v "$AI_DEVOPS_REEL_ASSETS_DIR:/app/assets:ro" \
                      -v "$AI_DEVOPS_REEL_MODEL_CACHE_DIR:/root/.local/share/tts" \
                      -v "$AI_DEVOPS_REEL_LIVEPORTRAIT_DIR:/content/LivePortrait" \
                      -v "$AI_DEVOPS_REEL_WAV2LIP_DIR:/content/Wav2Lip" \
                      "$AI_DEVOPS_REEL_IMAGE"

                    docker ps --filter "name=$AI_DEVOPS_REEL_CONTAINER"
                    sleep 5
                    docker logs "$AI_DEVOPS_REEL_CONTAINER" --tail=120
                '''
            }
        }

        stage('Setup Kubeconfig') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        mkdir -p $HOME/.kube
                        cp $KUBECONFIG_FILE $HOME/.kube/config
                    '''
                }
            }
        }

        stage('Apply Kubernetes') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "📦 Applying prod manifests..."
                    kubectl apply -k k8s/overlays/prod
                '''
            }
        }

        stage('Sync Backend Secrets') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'razorpay-secret-id-prod', variable: 'RAZORPAY_SECRET_ID'),
                    string(credentialsId: 'razorpay-secret-key-prod', variable: 'RAZORPAY_SECRET_KEY'),
                    string(credentialsId: 'razorpay-webhook-secret-prod', variable: 'RAZORPAY_WEBHOOK_SECRET'),
                    string(credentialsId: 'groq-api-key-prod', variable: 'GROQ_API_KEY')
                ]) {
                    sh '''
                        set -e
                        export KUBECONFIG=$HOME/.kube/config

                        echo "🔐 Syncing backend prod secrets..."
                        kubectl create secret generic "$BACKEND_SECRET_NAME" \
                          --from-literal=RAZORPAY_SECRET_ID="$RAZORPAY_SECRET_ID" \
                          --from-literal=RAZORPAY_SECRET_KEY="$RAZORPAY_SECRET_KEY" \
                          --from-literal=RAZORPAY_WEBHOOK_SECRET="$RAZORPAY_WEBHOOK_SECRET" \
                          --from-literal=GROQ_API_KEY="$GROQ_API_KEY" \
                          --from-literal=FRONTEND_URL="https://tutorlix.com" \
                          --dry-run=client -o yaml | kubectl apply -f -

                        kubectl set env deployment/backend-prod --from=secret/"$BACKEND_SECRET_NAME"
                        kubectl describe secret "$BACKEND_SECRET_NAME" | sed -n '1,20p'
                    '''
                }
            }
        }

        stage('Rollout Prod Deployments') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "🔄 Updating deployment images..."
                    kubectl set image deployment/backend-prod backend-prod=$BACKEND_IMAGE
                    kubectl set image deployment/frontend-prod frontend-prod=$FRONTEND_IMAGE

                    echo "🔄 Restarting prod deployments..."
                    kubectl rollout restart deployment/backend-prod
                    kubectl rollout restart deployment/frontend-prod
                '''
            }
        }

        stage('Verify Deployments And Migrate') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            parallel {
                stage('Backend Rollout And Migrate') {
                    steps {
                        sh '''
                            export KUBECONFIG=$HOME/.kube/config

                            echo "⏳ Waiting for backend-prod rollout..."
                            kubectl rollout status deployment/backend-prod --timeout="$ROLLOUT_TIMEOUT" || {
                                echo "❌ backend-prod rollout did not complete"
                                kubectl get deployment backend-prod -o wide || true
                                kubectl describe deployment backend-prod || true
                                kubectl get pods -l app=backend-prod -o wide || true
                                kubectl describe pods -l app=backend-prod || true
                                kubectl logs deployment/backend-prod -c backend-prod --tail=200 || true
                                exit 1
                            }

                            BACKEND_POD=$(kubectl get pods -l app=backend-prod --sort-by=.metadata.creationTimestamp -o jsonpath='{.items[-1:].metadata.name}')
                            BACKEND_NODE=$(kubectl get pod "$BACKEND_POD" -o jsonpath='{.spec.nodeName}')
                            MIGRATE_JOB_NAME="backend-prod-migrate-$(date +%s)"

                            if [ -z "$BACKEND_POD" ] || [ -z "$BACKEND_NODE" ]; then
                                echo "❌ Could not resolve backend pod or node for migration job"
                                exit 1
                            fi

                            echo "🗄️ Running migrations in job $MIGRATE_JOB_NAME on node $BACKEND_NODE ..."
                            cat <<EOF | kubectl apply -f -
apiVersion: batch/v1
kind: Job
metadata:
  name: ${MIGRATE_JOB_NAME}
spec:
  backoffLimit: 0
  template:
    spec:
      nodeName: ${BACKEND_NODE}
      restartPolicy: Never
      containers:
        - name: migrate
          image: ${BACKEND_IMAGE}
          imagePullPolicy: Always
          command: ["python", "manage.py", "migrate"]
          envFrom:
            - secretRef:
                name: ${BACKEND_SECRET_NAME}
          volumeMounts:
            - name: db-storage
              mountPath: /app/db.sqlite3
            - name: media-storage
              mountPath: /app/media
      volumes:
        - name: db-storage
          hostPath:
            path: /var/www/tutorlix-prod/backend/db.sqlite3
            type: FileOrCreate
        - name: media-storage
          hostPath:
            path: /var/www/tutorlix-prod/backend/media
            type: DirectoryOrCreate
EOF

                            kubectl wait --for=condition=complete job/"$MIGRATE_JOB_NAME" --timeout=180s || {
                                kubectl logs job/"$MIGRATE_JOB_NAME" || true
                                kubectl describe job "$MIGRATE_JOB_NAME" || true
                                exit 1
                            }

                            kubectl logs job/"$MIGRATE_JOB_NAME"
                            kubectl delete job "$MIGRATE_JOB_NAME" --ignore-not-found=true
                        '''
                    }
                }

                stage('Frontend Rollout') {
                    steps {
                        sh '''
                            export KUBECONFIG=$HOME/.kube/config

                            echo "⏳ Waiting for frontend-prod rollout..."
                            kubectl rollout status deployment/frontend-prod --timeout="$ROLLOUT_TIMEOUT" || {
                                echo "❌ frontend-prod rollout did not complete"
                                kubectl get deployment frontend-prod -o wide || true
                                kubectl describe deployment frontend-prod || true
                                kubectl get pods -l app=frontend-prod -o wide || true
                                kubectl describe pods -l app=frontend-prod || true
                                kubectl logs deployment/frontend-prod -c frontend-prod --tail=200 || true
                                exit 1
                            }
                        '''
                    }
                }
            }
        }

        stage('Health Check') {
            when {
                expression { params.BUILD_TARGET == 'backend_frontend' }
            }
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "🔍 Pods:"
                    kubectl get pods -o wide

                    echo "🔍 Services:"
                    kubectl get svc
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Prod deploy successful"
        }
        failure {
            echo "❌ Prod deploy failed"
        }
    }
}
