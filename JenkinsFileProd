pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
        BACKEND_IMAGE = "${DOCKER_CREDS_USR}/tutorlix-backend-prod:latest"
        FRONTEND_IMAGE = "${DOCKER_CREDS_USR}/tutorlix-frontend-prod:latest"
        BACKEND_SECRET_NAME = 'backend-prod-env'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                '''
            }
        }

        stage('Build And Push Images') {
            parallel {
                stage('Backend Image') {
                    steps {
                        sh '''
                            echo "🚀 Building backend prod image..."
                            docker build \
                            --network=host \
                            -t $BACKEND_IMAGE \
                            ./backend

                            echo "📤 Pushing backend prod image..."
                            docker push $BACKEND_IMAGE
                        '''
                    }
                }

                stage('Frontend Image') {
                    steps {
                        sh '''
                            echo "🚀 Building frontend prod image..."
                            docker build \
                            --network=host \
                            -t $FRONTEND_IMAGE \
                            ./frontend

                            echo "📤 Pushing frontend prod image..."
                            docker push $FRONTEND_IMAGE
                        '''
                    }
                }
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        mkdir -p $HOME/.kube
                        cp $KUBECONFIG_FILE $HOME/.kube/config
                    '''
                }
            }
        }

        stage('Apply Kubernetes') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "📦 Applying prod manifests..."
                    kubectl apply -k k8s/overlays/prod
                '''
            }
        }

        stage('Sync Backend Secrets') {
            steps {
                withCredentials([
                    string(credentialsId: 'razorpay-secret-id-prod', variable: 'RAZORPAY_SECRET_ID'),
                    string(credentialsId: 'razorpay-secret-key-prod', variable: 'RAZORPAY_SECRET_KEY'),
                    string(credentialsId: 'razorpay-webhook-secret-prod', variable: 'RAZORPAY_WEBHOOK_SECRET'),
                    string(credentialsId: 'groq-api-key-prod', variable: 'GROQ_API_KEY')
                ]) {
                    sh '''
                        set -e
                        export KUBECONFIG=$HOME/.kube/config

                        echo "🔐 Syncing backend prod secrets..."
                        kubectl create secret generic "$BACKEND_SECRET_NAME" \
                          --from-literal=RAZORPAY_SECRET_ID="$RAZORPAY_SECRET_ID" \
                          --from-literal=RAZORPAY_SECRET_KEY="$RAZORPAY_SECRET_KEY" \
                          --from-literal=RAZORPAY_WEBHOOK_SECRET="$RAZORPAY_WEBHOOK_SECRET" \
                          --from-literal=GROQ_API_KEY="$GROQ_API_KEY" \
                          --from-literal=FRONTEND_URL="https://tutorlix.com" \
                          --dry-run=client -o yaml | kubectl apply -f -

                        kubectl set env deployment/backend-prod --from=secret/"$BACKEND_SECRET_NAME"
                        kubectl describe secret "$BACKEND_SECRET_NAME" | sed -n '1,20p'
                    '''
                }
            }
        }

        stage('Rollout Prod Deployments') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "🔄 Updating deployment images..."
                    kubectl set image deployment/backend-prod backend-prod=$BACKEND_IMAGE
                    kubectl set image deployment/frontend-prod frontend-prod=$FRONTEND_IMAGE

                    echo "🔄 Restarting prod deployments..."
                    kubectl rollout restart deployment/backend-prod
                    kubectl rollout restart deployment/frontend-prod
                '''
            }
        }

        stage('Verify Deployments And Migrate') {
            parallel {
                stage('Backend Rollout And Migrate') {
                    steps {
                        sh '''
                            export KUBECONFIG=$HOME/.kube/config

                            echo "⏳ Waiting for backend-prod rollout..."
                            kubectl rollout status deployment/backend-prod --timeout=180s

                            BACKEND_POD=$(kubectl get pods -l app=backend-prod --sort-by=.metadata.creationTimestamp -o jsonpath='{.items[-1:].metadata.name}')

                            if [ -z "$BACKEND_POD" ]; then
                                echo "❌ No backend-prod pod found for migrations"
                                exit 1
                            fi

                            echo "🗄️ Running migrations on $BACKEND_POD ..."
                            kubectl exec "$BACKEND_POD" -- python manage.py migrate
                        '''
                    }
                }

                stage('Frontend Rollout') {
                    steps {
                        sh '''
                            export KUBECONFIG=$HOME/.kube/config

                            echo "⏳ Waiting for frontend-prod rollout..."
                            kubectl rollout status deployment/frontend-prod --timeout=180s
                        '''
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "🔍 Pods:"
                    kubectl get pods -o wide

                    echo "🔍 Services:"
                    kubectl get svc
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Prod deploy successful"
        }
        failure {
            echo "❌ Prod deploy failed"
        }
    }
}
