pipeline {
    agent any

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('🔥 Pre-Cleanup (Fix Node Pressure)') {
            steps {
                sh '''
                    echo "💣 Cleaning Docker & system (prevent eviction)..."

                    docker system prune -a -f || true
                    docker volume prune -f || true
                '''
            }
        }

        stage('Build Images (NO CACHE)') {
            steps {
                sh '''
                    echo "🚀 Building Docker images (no cache)..."

                    docker build --no-cache --network=host \
                    -t $DOCKER_CREDS_USR/tutorlix-backend-prod:latest \
                    ./backend

                    docker build --no-cache --network=host \
                    -t $DOCKER_CREDS_USR/tutorlix-frontend-prod:latest \
                    ./frontend
                '''
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                '''
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                    echo "📤 Pushing images..."

                    docker push $DOCKER_CREDS_USR/tutorlix-backend-prod:latest
                    docker push $DOCKER_CREDS_USR/tutorlix-frontend-prod:latest
                '''
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        mkdir -p $HOME/.kube
                        cp $KUBECONFIG_FILE $HOME/.kube/config
                    '''
                }
            }
        }

        stage('🔥 Cluster Cleanup (Anti-Stuck Mode)') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "💣 Cleaning bad pods..."

                    # Remove completed/failed pods
                    kubectl delete pod --field-selector=status.phase=Succeeded || true
                    kubectl delete pod --field-selector=status.phase=Failed || true

                    # Remove evicted pods
                    kubectl get pods | grep Evicted | awk '{print $1}' | xargs -r kubectl delete pod || true

                    # Force delete broken pods
                    kubectl delete pod -l app=frontend-prod --force --grace-period=0 || true
                    kubectl delete pod -l app=frontend --force --grace-period=0 || true
                    kubectl delete pod -l app=backend --force --grace-period=0 || true
                '''
            }
        }

        stage('Apply Kubernetes') {
            steps {
                sh '''
                    echo "📦 Applying Kubernetes manifests..."

                    export KUBECONFIG=$HOME/.kube/config
                    kubectl apply -k k8s/overlays/prod
                '''
            }
        }

        stage('🔥 Hard Refresh (LATEST FIX)') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "💣 Forcing fresh deployment..."

                    kubectl set image deployment/backend-prod backend-prod=$DOCKER_CREDS_USR/tutorlix-backend-prod:latest --record
                    kubectl set image deployment/frontend-prod frontend-prod=$DOCKER_CREDS_USR/tutorlix-frontend-prod:latest --record

                    kubectl rollout restart deployment/backend-prod
                    kubectl rollout restart deployment/frontend-prod

                    # Kill old pods
                    kubectl delete pod -l app=backend-prod --force --grace-period=0 || true

                    # Restart monitoring stack
                    kubectl delete pod -l app=prometheus || true
                    kubectl delete pod -l app=node-exporter || true
                '''
            }
        }

        stage('⏳ Wait for Stable State') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "⏳ Waiting for backend..."
                    kubectl rollout status deployment/backend-prod --timeout=120s

                    echo "⏳ Waiting for frontend..."
                    kubectl rollout status deployment/frontend-prod --timeout=120s
                '''
            }
        }

        stage('🧪 Health Check') {
            steps {
                sh '''
                    export KUBECONFIG=$HOME/.kube/config

                    echo "🔍 Pods:"
                    kubectl get pods -o wide

                    echo "🔍 Services:"
                    kubectl get svc

                    echo "🔍 Backend metrics test:"
                    python -c "import urllib.request; print(urllib.request.urlopen('http://localhost:31235/metrics').read().decode()[:200])" || echo "❌ Metrics failed"

                    echo "🔍 Prometheus targets:"
                    curl -s http://localhost:30090/targets | grep UP || true
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deploy successful 🚀 (cluster healthy)"
        }
        failure {
            echo "❌ Deploy failed 💀 (check logs)"
        }
    }
}