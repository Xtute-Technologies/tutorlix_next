# Tutorlix .env example

# Django
SECRET_KEY=django-insecure-something
DEBUG=True
ALLOWED_HOSTS=localhost,back.tutorlix.com,dev.tutorlix.com,127.0.0.1,tutorlix.com,backend-prod

# Razorpay
RAZORPAY_SECRET_ID=rzp_test_something
RAZORPAY_SECRET_KEY=something
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
PIPER_TTS_URL=http://127.0.0.1:5000/

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=yourpassword
EMAIL_USE_TLS=True

#Livekit
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_WS_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_URL=https://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_TOKEN_TTL_SECONDS=21600
LIVEKIT_ROOM_PREFIX=tutorlix
LIVEKIT_MEETING_BASE_URL=
LIVEKIT_MIN_CONCURRENT_CLASSES=10
LIVEKIT_AI_AGENT_NAME=tutorlix-ai-tutor


# Frontend
FRONTEND_URL=https://tutorlix.com
