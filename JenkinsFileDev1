pipeline {
    agent any

    environment {
        IMAGE_BACKEND = "tutorlix-backend"
        IMAGE_FRONTEND = "tutorlix-frontend"
        KUBE_NAMESPACE = "default"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Set Minikube Docker Env') {
            steps {
                sh '''
                    echo "🔗 Connecting to Minikube Docker..."
                    eval $(minikube docker-env)
                '''
            }
        }

        stage('Build Images') {
            steps {
                sh '''
                    echo "🏗️ Building Docker images..."

                    eval $(minikube docker-env)

                    docker build -t $IMAGE_BACKEND ./backend
                    docker build -t $IMAGE_FRONTEND ./frontend
                '''
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    echo "🚀 Applying Kubernetes manifests..."

                    kubectl apply -f k8s/
                '''
            }
        }

        stage('Restart Deployments') {
            steps {
                sh '''
                    echo "🔄 Restarting deployments..."

                    kubectl rollout restart deployment backend
                    kubectl rollout restart deployment frontend
                '''
            }
        }

        stage('Run Migrations') {
            steps {
                sh '''
                    echo "📦 Running migrations..."

                    kubectl exec deployment/backend -- python manage.py migrate
                    kubectl exec deployment/backend -- python manage.py collectstatic --noinput
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                    echo "🔍 Checking pods..."

                    kubectl get pods
                    kubectl get svc
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Kubernetes deploy succeeded 🚀"
        }
        failure {
            echo "❌ Kubernetes deploy failed"
        }
    }
}