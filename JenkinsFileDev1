pipeline {
    agent any

    parameters {
        choice(
            name: 'DEPLOY_SCOPE', 
            choices: ['All', 'Frontend', 'Backend'], 
            description: 'Choose which components to deploy.'
        )
    }

    environment {
        COMPOSE_FILE = "docker-compose.yml"
        PROJECT_NAME = "tutorlix"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "🚀 Starting Docker Deploy: ${params.DEPLOY_SCOPE}"
                checkout scm
            }
        }

        stage('Stop Existing Containers') {
            steps {
                sh '''
                    echo "🛑 Stopping old containers..."
                    docker compose down || true
                '''
            }
        }

        stage('Build Docker Images') {
            when { 
                expression { return params.DEPLOY_SCOPE == 'All' || params.DEPLOY_SCOPE == 'Frontend' || params.DEPLOY_SCOPE == 'Backend' } 
            }
            steps {
                sh '''
                    echo "🏗️ Building Docker images..."
                    docker compose build --no-cache
                '''
            }
        }

        stage('Run Containers') {
            steps {
                sh '''
                    echo "🚀 Starting containers..."
                    docker compose up -d
                '''
            }
        }

        stage('Run Migrations') {
            when { 
                expression { return params.DEPLOY_SCOPE == 'All' || params.DEPLOY_SCOPE == 'Backend' } 
            }
            steps {
                sh '''
                    echo "📦 Running Django migrations..."
                    docker exec backend python manage.py migrate

                    echo "📁 Collecting static..."
                    docker exec backend python manage.py collectstatic --noinput
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    echo "🔍 Checking backend health..."
                    curl -f http://localhost:8000 || exit 1

                    echo "🔍 Checking frontend health..."
                    curl -f http://localhost:3000 || exit 1
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Docker deploy succeeded 🚀"
        }
        failure {
            echo "❌ Docker deploy failed"
        }
    }
}