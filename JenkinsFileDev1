pipeline {
    agent any

    options {
        timestamps()
    }

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Images') {
            parallel {
                stage('Build Backend') {
                    steps {
                        sh '''
                            echo "🚀 Building backend image with cache..."
                            docker build \
                            --network=host \
                            -t $DOCKER_CREDS_USR/tutorlix-backend:latest \
                            ./backend
                        '''
                    }
                }

                stage('Build Frontend') {
                    steps {
                        sh '''
                            echo "🚀 Building frontend image with cache..."
                            docker build \
                            --network=host \
                            -t $DOCKER_CREDS_USR/tutorlix-frontend:latest \
                            ./frontend
                        '''
                    }
                }
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                '''
            }
        }

        stage('Push Images') {
            parallel {
                stage('Push Backend') {
                    steps {
                        sh '''
                            echo "📤 Pushing backend image..."
                            docker push $DOCKER_CREDS_USR/tutorlix-backend:latest
                        '''
                    }
                }

                stage('Push Frontend') {
                    steps {
                        sh '''
                            echo "📤 Pushing frontend image..."
                            docker push $DOCKER_CREDS_USR/tutorlix-frontend:latest
                        '''
                    }
                }
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        mkdir -p $HOME/.kube
                        cp $KUBECONFIG_FILE $HOME/.kube/config
                    '''
                }
            }
        }

        stage('Apply Kubernetes') {
            steps {
                sh '''
                    echo "📦 Applying Kubernetes manifests..."

                    export KUBECONFIG=$HOME/.kube/config

                    kubectl apply -k k8s/overlays/vps
                '''
            }
        }

        stage('Force Fresh Deployment') {
            steps {
                sh '''
                    echo "♻️ Forcing fresh pods (no cache)..."

                    export KUBECONFIG=$HOME/.kube/config

                    kubectl rollout restart deployment/backend
                    kubectl rollout restart deployment/frontend
                '''
            }
        }

        stage('Run Migrations') {
            steps {
                sh '''
                    echo "🗃️ Running Django migrations..."

                    export KUBECONFIG=$HOME/.kube/config

                    BACKEND_POD=$(kubectl get pods -l app=backend --sort-by=.metadata.creationTimestamp -o jsonpath='{.items[-1:].metadata.name}')

                    if [ -z "$BACKEND_POD" ]; then
                        echo "❌ No backend pod found for migrations"
                        exit 1
                    fi

                    if ! kubectl wait --for=condition=Ready pod/$BACKEND_POD --timeout=90s; then
                        echo "❌ Backend pod did not become ready"
                        echo "📋 Deployment description:"
                        kubectl describe deployment/backend || true
                        echo "📋 Pod description:"
                        kubectl describe pod/$BACKEND_POD || true
                        echo "📋 Backend logs:"
                        kubectl logs $BACKEND_POD --tail=200 || true
                        exit 1
                    fi

                    kubectl exec "$BACKEND_POD" -- python manage.py migrate
                '''
            }
        }

        stage('Rollout Wait') {
            parallel {
                stage('Wait Backend') {
                    steps {
                        sh '''
                            echo "⏳ Waiting for backend rollout..."

                            export KUBECONFIG=$HOME/.kube/config

                            kubectl rollout status deployment/backend --timeout=90s
                        '''
                    }
                }

                stage('Wait Frontend') {
                    steps {
                        sh '''
                            echo "⏳ Waiting for frontend rollout..."

                            export KUBECONFIG=$HOME/.kube/config

                            kubectl rollout status deployment/frontend --timeout=90s
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✅ Deploy successful 🚀"
        }
        failure {
            echo "❌ Deploy failed"
        }
    }
}
