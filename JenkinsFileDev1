pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
        DOCKER_BUILDKIT = '1'
        COMPOSE_DOCKER_CLI_BUILD = '1'
        BACKEND_IMAGE = 'ankitvashishta7/tutorlix-backend'
        FRONTEND_IMAGE = 'ankitvashishta7/tutorlix-frontend'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    set -e
                    echo "$DOCKER_CREDS_PSW" | docker login -u "$DOCKER_CREDS_USR" --password-stdin
                '''
            }
        }

        stage('Build And Push Images') {
            parallel {
                stage('Backend Image') {
                    steps {
                        sh '''
                            set -e
                            echo "🚀 Building backend image..."
                            docker build \
                              --network=host \
                              -t "$BACKEND_IMAGE:$IMAGE_TAG" \
                              -t "$BACKEND_IMAGE:latest" \
                              ./backend

                            echo "📤 Pushing backend image..."
                            docker push "$BACKEND_IMAGE:$IMAGE_TAG"
                            docker push "$BACKEND_IMAGE:latest"

                            echo "🧹 Cleaning local backend image..."
                            docker image rm "$BACKEND_IMAGE:$IMAGE_TAG" "$BACKEND_IMAGE:latest" || true
                        '''
                    }
                }

                stage('Frontend Image') {
                    steps {
                        sh '''
                            set -e
                            echo "🚀 Building frontend image..."
                            docker build \
                              --network=host \
                              -t "$FRONTEND_IMAGE:$IMAGE_TAG" \
                              -t "$FRONTEND_IMAGE:latest" \
                              ./frontend

                            echo "📤 Pushing frontend image..."
                            docker push "$FRONTEND_IMAGE:$IMAGE_TAG"
                            docker push "$FRONTEND_IMAGE:latest"

                            echo "🧹 Cleaning local frontend image..."
                            docker image rm "$FRONTEND_IMAGE:$IMAGE_TAG" "$FRONTEND_IMAGE:latest" || true
                        '''
                    }
                }
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        set -e
                        mkdir -p "$HOME/.kube"
                        cp "$KUBECONFIG_FILE" "$HOME/.kube/config"
                        chmod 600 "$HOME/.kube/config"
                    '''
                }
            }
        }

        stage('Cluster Preflight') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG="$HOME/.kube/config"

                    echo "🔎 Cluster health check..."
                    kubectl get nodes -o wide

                    echo "🧹 Cleaning failed/evicted pods..."
                    kubectl delete pod --field-selector=status.phase=Failed --all-namespaces --ignore-not-found=true || true

                    echo "🧹 Cleaning completed pods..."
                    kubectl delete pod --field-selector=status.phase=Succeeded --all-namespaces --ignore-not-found=true || true

                    echo "📋 Recent node events..."
                    kubectl get events --sort-by=.lastTimestamp | tail -30 || true

                    if kubectl describe node | grep -qi 'disk-pressure'; then
                        echo "❌ Node still has DiskPressure. Free disk space first."
                        df -h || true
                        exit 1
                    fi
                '''
            }
        }

        stage('Apply Manifests And Update Images') {
            steps {
                sh '''
                    set -e
                    export KUBECONFIG="$HOME/.kube/config"

                    echo "📦 Applying manifests..."
                    kubectl apply -k k8s/overlays/vps

                    echo "🖼️ Updating images with immutable tags..."
                    kubectl set image deployment/backend backend="$BACKEND_IMAGE:$IMAGE_TAG"
                    kubectl set image deployment/frontend frontend="$FRONTEND_IMAGE:$IMAGE_TAG"
                '''
            }
        }

        stage('Verify Deployments') {
            parallel {
                stage('Backend Rollout And Migrate') {
                    steps {
                        sh '''
                            set -e
                            export KUBECONFIG="$HOME/.kube/config"

                            echo "⏳ Waiting for backend rollout..."
                            if ! kubectl rollout status deployment/backend --timeout=240s; then
                                echo "❌ Backend rollout failed. Debug info:"
                                kubectl get deployment backend -o wide || true
                                kubectl describe deployment backend || true
                                kubectl get rs -l app=backend -o wide || true
                                kubectl get pods -l app=backend -o wide || true
                                kubectl describe pods -l app=backend || true
                                kubectl get events --sort-by=.lastTimestamp | tail -40 || true
                                exit 1
                            fi

                            echo "🔍 Finding running backend pod..."
                            BACKEND_POD=$(kubectl get pods -l app=backend \
                              --field-selector=status.phase=Running \
                              --sort-by=.metadata.creationTimestamp \
                              -o jsonpath='{.items[-1:].metadata.name}')

                            if [ -z "$BACKEND_POD" ]; then
                                echo "❌ No running backend pod found"
                                kubectl get pods -l app=backend -o wide || true
                                exit 1
                            fi

                            echo "🗄️ Running migrations in $BACKEND_POD ..."
                            kubectl exec "$BACKEND_POD" -- python manage.py migrate
                        '''
                    }
                }

                stage('Frontend Rollout') {
                    steps {
                        sh '''
                            set -e
                            export KUBECONFIG="$HOME/.kube/config"

                            echo "⏳ Waiting for frontend rollout..."
                            if ! kubectl rollout status deployment/frontend --timeout=240s; then
                                echo "❌ Frontend rollout failed. Debug info:"
                                kubectl get deployment frontend -o wide || true
                                kubectl describe deployment frontend || true
                                kubectl get rs -l app=frontend -o wide || true
                                kubectl get pods -l app=frontend -o wide || true
                                kubectl describe pods -l app=frontend || true
                                kubectl get events --sort-by=.lastTimestamp | tail -40 || true
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            sh '''
                echo "🧹 Final Docker cleanup..."
                docker image prune -af || true
                docker builder prune -af || true
                docker volume prune -f || true
            '''
        }
        success {
            echo "✅ Deploy successful 🚀"
        }
        failure {
            echo "❌ Deploy failed"
        }
    }
}