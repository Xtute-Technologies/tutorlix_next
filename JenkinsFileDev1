pipeline {
    agent any

    environment {
        DOCKER_CREDS = credentials('dockerhub')
        KUBE_CONFIG = credentials('kubeconfig')
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Images') {
            steps {
                sh '''
                    echo "🚀 Building Docker images..."

                    docker build \
                    --network=host \
                    -t $DOCKER_CREDS_USR/tutorlix-backend:$IMAGE_TAG \
                    ./backend

                    docker build \
                    --network=host \
                    -t $DOCKER_CREDS_USR/tutorlix-frontend:$IMAGE_TAG \
                    ./frontend
                '''
            }
        }

        stage('Docker Login') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                '''
            }
        }

        stage('Push Images') {
            steps {
                sh '''
                    docker push $DOCKER_CREDS_USR/tutorlix-backend:$IMAGE_TAG
                    docker push $DOCKER_CREDS_USR/tutorlix-frontend:$IMAGE_TAG
                '''
            }
        }

        stage('Setup Kubeconfig') {
            steps {
                sh '''
                    mkdir -p $HOME/.kube
                    echo "$KUBE_CONFIG" > $HOME/.kube/config
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    echo "🚀 Deploying to Kubernetes..."

                    kubectl set image deployment/backend \
                      backend=$DOCKER_CREDS_USR/tutorlix-backend:$IMAGE_TAG

                    kubectl set image deployment/frontend \
                      frontend=$DOCKER_CREDS_USR/tutorlix-frontend:$IMAGE_TAG
                '''
            }
        }

        stage('Rollout Wait') {
            steps {
                sh '''
                    kubectl rollout status deployment/backend
                    kubectl rollout status deployment/frontend
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Deploy successful"
        }
        failure {
            echo "❌ Deploy failed"
        }
    }
}