# Keep this file as a template. Put real values in bots/yehp_banner_bot/.env.

BOT_BRAND_NAME=YEHP
BOT_BRAND_TAGLINE=Doctor-guided herbal wellness
BOT_LOGO_URL=
BOT_WEBSITE_URL=
BOT_CONTACT_ADDRESS=Shop No. F19-F23, Eldeco Station 1 Mall, Sector 12, Faridabad 121007
BOT_CONTACT_PHONE=+91-8168654010
BOT_CONTENT_FILE=bots/yehp_banner_bot/content.json
BOT_OUTPUT_DIR=bots/yehp_banner_bot/output
BOT_POST_INTERVAL_SECONDS=21600
BOT_DRY_RUN=true

# The output directory must be served from this public HTTPS URL.
# Example: https://cdn.example.com/yehp-banners
PUBLIC_MEDIA_BASE_URL=

# Meta / Instagram API settings.
IG_USER_ID=
IG_ACCESS_TOKEN=
META_GRAPH_API_BASE_URL=https://graph.facebook.com
META_GRAPH_API_VERSION=v25.0

# OpenAI image background generation.
OPENAI_API_KEY=
OPENAI_IMAGE_ENABLED=true
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_TIMEOUT_SECONDS=180

# Optional API timing controls.
BOT_REQUEST_TIMEOUT_SECONDS=30
BOT_PUBLISH_POLL_SECONDS=5
BOT_PUBLISH_WAIT_SECONDS=60
