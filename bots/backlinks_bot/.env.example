# Keep this file as a template. Put real values in bots/backlinks_bot/.env.

BACKLINKS_BOT_OUTPUT_DIR=bots/backlinks_bot/output
BACKLINKS_BOT_STATE_FILE=bots/backlinks_bot/output/state.json
BACKLINKS_BOT_BACKLINKS_FILE=bots/backlinks_bot/backlinks.json
BACKLINKS_BOT_TARGETS_FILE=bots/backlinks_bot/targets.json

# 4 hours.
BACKLINKS_BOT_INTERVAL_SECONDS=14400
BACKLINKS_BOT_POSTS_PER_RUN=1
BACKLINKS_BOT_DRY_RUN=true
BACKLINKS_BOT_REQUEST_TIMEOUT_SECONDS=30
BACKLINKS_BOT_LINK_REL=noopener
BACKLINKS_BOT_USER_AGENT=TutorlixBacklinksBot/1.0 (+https://tutorlix.com)

# Example target credentials referenced by targets.json.
OWNED_WORDPRESS_USERNAME=
OWNED_WORDPRESS_APP_PASSWORD=
OWNED_CUSTOM_SITE_TOKEN=

