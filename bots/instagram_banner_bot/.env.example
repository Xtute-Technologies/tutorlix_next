# Keep this file as a template. Put real values in bots/instagram_banner_bot/.env.

BOT_BRAND_NAME=Tutorlix
BOT_BRAND_TAGLINE=Learn smarter. Grow faster.
BOT_CONTENT_FILE=bots/instagram_banner_bot/content.json
BOT_OUTPUT_DIR=bots/instagram_banner_bot/output
BOT_POST_SCHEDULE_TIMES=11:00,17:00
BOT_SCHEDULE_TIMEZONE=Asia/Kolkata
BOT_RUN_ON_START=true
# Used only if BOT_POST_SCHEDULE_TIMES is empty.
BOT_POST_INTERVAL_SECONDS=7200
BOT_DRY_RUN=true
BOT_PUBLISH_MEDIA_TYPE=reel
BOT_REEL_DURATION_SECONDS=8
BOT_REEL_SHARE_TO_FEED=true
BOT_REEL_AUDIO_FILE=bots/instagram_banner_bot/bombinsound-trending-instagram-reels-music-499599.mp3

# The output directory must be served from this public HTTPS URL.
# Example: https://cdn.example.com/instagram-banners
PUBLIC_MEDIA_BASE_URL=

# Meta / Instagram API settings.
IG_USER_ID=17841461591480202
