# Keep this file as a template. Put real values in bots/linkedin_banner_bot/.env.

BOT_BRAND_NAME=Tutorlix
BOT_BRAND_TAGLINE=Learn smarter. Grow faster.
BOT_CONTENT_FILE=bots/linkedin_banner_bot/content.json
BOT_OUTPUT_DIR=bots/linkedin_banner_bot/output
BOT_POST_SCHEDULE_TIMES=11:00,17:00
BOT_SCHEDULE_TIMEZONE=Asia/Kolkata
BOT_RUN_ON_START=true
# Used only if BOT_POST_SCHEDULE_TIMES is empty.
BOT_POST_INTERVAL_SECONDS=7200
BOT_DRY_RUN=true

# The output directory must be served from this public HTTPS URL.
# Example: https://cdn.example.com/linkedin-banners
PUBLIC_MEDIA_BASE_URL=

# Buffer API settings. BUFFER_CHANNEL_IDS should be the LinkedIn channel id
# from Buffer. Multiple ids can be comma-separated if needed.
BUFFER_API_KEY=
BUFFER_CHANNEL_IDS=
BUFFER_API_BASE_URL=https://api.buffer.com
BUFFER_POST_MODE=shareNow
BUFFER_SCHEDULING_TYPE=automatic

# Optional API timing controls.
BOT_REQUEST_TIMEOUT_SECONDS=30

# Optional banner background generation.
OPENAI_API_KEY=
OPENAI_IMAGE_ENABLED=false
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_PROMPT=Create a square no-text online learning banner background for {brand_name}. Leave room for text overlays.
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_TIMEOUT_SECONDS=180
